# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for JWT auth
JWT_SECRET=your-random-32-byte-hex-secret

# Optional — enables screenshot in analysis
SCREENSHOT_API_KEY=your-screenshotone-key

# Optional — enables traffic/index signals
SERPAPI_KEY=your-serpapi-key

# Set to true to bypass usage limits (for demos and internal use)
DEMO_MODE=false

# Result cache TTL in milliseconds (default: 1 hour)
CACHE_TTL_MS=3600000

# Admin secret for /admin dashboard
ADMIN_SECRET=

# Server port
PORT=3010

# ── Stripe (card payments) ────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a recurring price at https://dashboard.stripe.com/products
STRIPE_PRICE_ID=price_...
# Your deployed app URL (used for Stripe redirect)
APP_URL=https://your-app.onrender.com

# ── Solana Pay (crypto payments) ──────────────────────────
# Your Solana wallet address to receive USDC
SOLANA_PAY_RECIPIENT=YourSolanaWalletAddressHere
# Amount in USDC (default 29)
SOLANA_PAY_AMOUNT_USDC=29
